# EPG Live Paper Trading — Environment Variables
# Copy to live/.env and fill in values before starting.
# Never commit live/.env — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg connection string for the PostgreSQL database.
# Docker default: postgresql://epg:password@db:5432/epg_live
DB_URL=postgresql://epg:CHANGE_ME@db:5432/epg_live
# Local connection string used by smoke_test.py (run from host, not inside Docker).
# Uses localhost because the 'db' hostname only resolves inside Docker networking.
DB_URL_LOCAL=postgresql://epg:CHANGE_ME@localhost:5433/epg_live

# ── Polygon ───────────────────────────────────────────────────────────────────
# Polygon.io API key. Requires Starter tier or above for WebSocket access.
POLYGON_API_KEY=

# ── IBKR (Interactive Brokers) ────────────────────────────────────────────────
# IB Gateway connection details.
# IB Gateway paper port: 4002  |  IB Gateway live port: 4001
# On Docker Desktop (Windows/Mac), set IBKR_HOST=host.docker.internal
IBKR_HOST=host.docker.internal
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather. Chat ID of your private chat with the bot.
# Get chat ID: send a message to the bot, then call
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Data Export ───────────────────────────────────────────────────────────────
# Root directory for session parquet export (mirrors backtest DATA_ROOT).
# On the Docker container this maps to the host filtered/ catalog volume.
# Windows host example: D:\Trading Research\data
DATA_ROOT=/data
